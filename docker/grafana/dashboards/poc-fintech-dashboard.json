{
  "annotations": {
    "list": []
  },
  "description": "POC Fintech — Production metrics: JVM, HTTP, Transfers, Outbox, Resilience4j",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "📊 Transfer Operations",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "title": "Transfers Initiated (Total)",
      "type": "stat",
      "targets": [
        {
          "expr": "fintech_transfers_initiated_total",
          "legendFormat": "initiated"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "green" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "title": "Transfers Completed (Total)",
      "type": "stat",
      "targets": [
        {
          "expr": "fintech_transfers_completed_total",
          "legendFormat": "completed"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "red" }, "thresholds": { "steps": [{ "color": "red", "value": null }] } }
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "title": "Transfers Failed (Total)",
      "type": "stat",
      "targets": [
        {
          "expr": "fintech_transfers_failed_total",
          "legendFormat": "failed"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "title": "Transfer Duration (p99)",
      "type": "stat",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(fintech_transfer_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "id": 5,
      "title": "Transfer Rate (per second)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(fintech_transfers_initiated_total[1m])",
          "legendFormat": "initiated/s"
        },
        {
          "expr": "rate(fintech_transfers_completed_total[1m])",
          "legendFormat": "completed/s"
        },
        {
          "expr": "rate(fintech_transfers_failed_total[1m])",
          "legendFormat": "failed/s"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "id": 6,
      "title": "Transfer Duration Histogram (p50, p95, p99)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(fintech_transfer_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(fintech_transfer_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(fintech_transfer_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 101,
      "title": "🌐 HTTP Server",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 10,
      "title": "HTTP Request Rate by Endpoint",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{uri=~\"/api/.*\"}[1m]))",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 11,
      "title": "HTTP Response Time (p95) by Endpoint",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (uri, le) (rate(http_server_requests_seconds_bucket{uri=~\"/api/.*\"}[5m])))",
          "legendFormat": "{{uri}} p95"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 12,
      "title": "HTTP Error Rate (4xx + 5xx)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (status) (rate(http_server_requests_seconds_count{status=~\"4..|5..\"}[1m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 102,
      "title": "📨 Outbox & Kafka",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 33 },
      "id": 20,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "title": "Outbox Events Published (Total)",
      "type": "stat",
      "targets": [
        {
          "expr": "fintech_outbox_events_published_total",
          "legendFormat": "published"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 39 },
      "id": 21,
      "title": "Outbox Publish Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(fintech_outbox_events_published_total[1m])",
          "legendFormat": "events/s"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 47 },
      "id": 103,
      "title": "🛡️ Resilience4j",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
      "id": 30,
      "title": "Circuit Breaker State",
      "type": "timeseries",
      "targets": [
        {
          "expr": "resilience4j_circuitbreaker_state{name=\"fraudDetection\"}",
          "legendFormat": "{{name}} — {{state}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 48 },
      "id": 31,
      "title": "Retry Call Rate (Fraud Detection)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(resilience4j_retry_calls_total{name=\"fraudDetection\"}[1m])",
          "legendFormat": "{{kind}}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 56 },
      "id": 104,
      "title": "☕ JVM Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
